@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            height: 100vh;
            margin: 0;
            background: linear-gradient(to right, #f3f0ff, #f8f9fa);
        }

        .split-container {
            display: flex;
            height: 100vh;
        }

        /* KEEP 50/50 */
        .left-side {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        .right-side {
            flex: 1;
            position: relative;
            background: url('https://images.unsplash.com/photo-1506157786151-b8491531f063?q=80&w=1600&auto=format&fit=crop') center center / cover no-repeat;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

            .right-side .overlay {
                position: absolute;
                inset: 0;
                background: linear-gradient( rgba(40, 0, 80, 0.75), rgba(70, 0, 120, 0.75) );
            }

            .right-side .content {
                position: relative;
                z-index: 2;
                text-align: center;
                color: white;
            }

        /* TALLER CARD */
        .card-custom {
            width: 100%;
            max-width: 650px;
            height: 75vh; /* 🔥 makes it tall */
            padding: 80px 70px;
            border-radius: 22px;
            box-shadow: 0 25px 70px rgba(0,0,0,0.2);
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand {
            color: #7b4bff;
            font-weight: bold;
            font-size: 26px;
            text-align: center;
            margin-bottom: 30px;
        }

        h5 {
            font-size: 24px;
        }

        .form-control {
            padding: 16px 20px;
            font-size: 16px;
            border-radius: 8px;
        }

        .btn-purple {
            background-color: #7b4bff;
            color: white;
            border: none;
            padding: 12px;
            font-size: 16px;
            border-radius: 8px;
        }

            .btn-purple:hover {
                background-color: #6938e6;
            }

        
    </style>
</head>
<body>

    <div class="split-container">

        <!-- LEFT SIDE (REGISTER FORM) -->
        <div class="left-side">
            <div class="card card-custom">

                <div class="brand">🎟 Ticket System</div>

                <h5 class="text-center mb-4">Create Your Account</h5>

                @if (TempData["Error"] != null)
                {
                    <div class="text-danger text-center mb-3">@TempData["Error"]</div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="text-success text-center mb-3">@TempData["Success"]</div>
                }

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <input name="email" class="form-control" placeholder="Email" required />
                    </div>

                    <div class="mb-4">
                        <input name="password" type="password" class="form-control" placeholder="Password" required />
                    </div>

                    <button type="submit" class="btn btn-purple w-100">
                        Register
                    </button>
                </form>

                <div class="text-center mt-4">
                    Already have an account?
                    <a asp-action="Login">Login</a>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE DESIGN PANEL -->
        <div class="right-side d-none d-md-flex">

            <div class="overlay"></div>

            <div class="content px-4">
                <h1 class="display-5 fw-bold mb-3">
                    🎤 Renaissance World Tour
                </h1>

                <p class="lead mb-4">
                    Experience the magic. <br />
                    Book your seat. <br />
                    Join the BeyHive.
                </p>

                <div class="mb-4">
                    <span class="badge bg-light text-dark p-2 me-2">Johannesburg</span>
                    <span class="badge bg-light text-dark p-2 me-2">December 2025</span>
                    <span class="badge bg-light text-dark p-2">Limited Seats</span>
                </div>

                <div class="fs-3 fw-bold">
                    R500 – R3000
                </div>
            </div>

        </div>

    </div>

</body>
</html>